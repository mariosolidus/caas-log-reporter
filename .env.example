# Railway API token (from railway.com/account/tokens)
RAILWAY_API_TOKEN=your_railway_token_here

# Anthropic Claude API key
ANTHROPIC_API_KEY=your_anthropic_key_here

# Resend API key (from resend.com)
RESEND_API_KEY=your_resend_key_here

# Railway CaaS project ID (pre-configured)
RAILWAY_PROJECT_ID=369a7aa0-a3a0-4d79-9768-8dc7e5207319

# Email recipient
REPORT_EMAIL=mam@soliduscapital.io

# Set to "true" to run the report immediately on startup (for testing)
RUN_NOW=false
